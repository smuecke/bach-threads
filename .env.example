SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_USER_TOKEN=xoxp-your-user-token
SLACK_SIGNING_SECRET=your-signing-secret

# Optional. Required only if you run with Socket Mode.
SLACK_APP_TOKEN=xapp-your-app-level-token

# Optional bootstrap list of users who can trigger the organizer and manage the
# whitelist. Slack admins/owners can manage the whitelist even if this is empty.
INITIAL_WHITELIST_USER_IDS=U1234567890,U2345678901
WHITELIST_FILE=data/whitelist.json

# Slack's :thread: emoji name is "thread".
THREAD_EMOJI=thread
